# Server
PORT=8080
ENV=development
LOG_LEVEL=debug

# Database — Neon Mumbai for prod, local postgres for dev
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kashmir?sslmode=disable

# Cache + queue
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-prod-make-it-long-and-random
JWT_REFRESH_SECRET=also-change-me
JWT_ACCESS_TTL_HOURS=24
JWT_REFRESH_TTL_DAYS=30

# Phone OTP — MSG91 for India delivery
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
OTP_DEV_BYPASS=true                       # In dev, accept "000000" as OTP for any phone

# OAuth — Google + Apple
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_CLIENT_ID=

# Object storage — Supabase Storage (S3-compatible), active image backend.
# Storage → Settings → S3 access keys. Region is the project's region.
SUPABASE_PROJECT_REF=
SUPABASE_REGION=ap-south-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_BUCKET=kashmir-uploads
# Leave blank to default to the bucket's public object URL (public buckets only).
SUPABASE_PUBLIC_BASE=

# Payments — Razorpay (India-first)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# AI — Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-7-20251101

# Weather — IMD doesn't have a public API key; we proxy
OPENWEATHERMAP_API_KEY=

# External advisory sources polled by internal/advisory.
# Leave blank to disable a source entirely (the fetcher will skip it).
# The defaults below are the historical public endpoints; if either is
# misbehaving in your environment, just blank the corresponding line.
NDMA_URL=https://sachet.ndma.gov.in/cap_public_website/getAllActiveWarnings
IMD_URL=https://mausam.imd.gov.in/backend/website/district-level-warning

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
