# Server
PORT=8080
ENV=development
LOG_LEVEL=debug

# Database — Neon Mumbai for prod, local postgres for dev
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kashmir?sslmode=disable

# Cache + queue
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-prod-make-it-long-and-random
JWT_REFRESH_SECRET=also-change-me
JWT_ACCESS_TTL_HOURS=24
JWT_REFRESH_TTL_DAYS=30

# Phone OTP — MSG91 for India delivery
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
OTP_DEV_BYPASS=true                       # In dev, accept "000000" as OTP for any phone

# OAuth — Google + Apple
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_CLIENT_ID=

# Object storage — Cloudflare R2 (egress-free)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kashmir-uploads
R2_PUBLIC_BASE=https://media.kashmir.app

# Payments — Razorpay (India-first)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# AI — Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-7-20251101

# Weather — IMD doesn't have a public API key; we proxy
OPENWEATHERMAP_API_KEY=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
